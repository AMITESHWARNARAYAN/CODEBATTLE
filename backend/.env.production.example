# Production Environment Variables
# Copy this file to .env.production and fill in your actual values
# NEVER commit .env.production to git

# MongoDB Connection String (Production)
# Get from MongoDB Atlas: https://www.mongodb.com/cloud/atlas
# Format: mongodb+srv://username:password@cluster.mongodb.net/dbname
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/codebattle

# JWT Secret (Minimum 32 characters, use a strong random string)
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long-1234567890

# Groq API Key (for AI explanations)
# Get from: https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# Gemini API Key (for AI features)
# Get from: https://aistudio.google.com/app/apikeys
GEMINI_API_KEY=your_gemini_api_key_here

# Node Environment
NODE_ENV=production

# Server Port (Vercel will override this)
PORT=5000

# Frontend URL (for CORS)
FRONTEND_URL=https://your-vercel-domain.vercel.app

# Backend URL (for frontend API calls)
BACKEND_URL=https://your-backend-url.vercel.app

# Optional: Sentry for error tracking
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Optional: Email service (for notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# Optional: Redis (for caching/sessions)
# REDIS_URL=redis://username:password@host:port

# Optional: AWS S3 (for file uploads)
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_S3_BUCKET=your-bucket-name
# AWS_REGION=us-east-1

